# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Random long random string used to sign admin session cookies.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# Razorpay keys — from https://dashboard.razorpay.com/app/keys
# RAZORPAY_KEY_ID is also exposed to the browser (checkout widget needs it),
# RAZORPAY_KEY_SECRET must stay server-side only.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook secret — set the same value in the Razorpay Dashboard > Webhooks
RAZORPAY_WEBHOOK_SECRET=
